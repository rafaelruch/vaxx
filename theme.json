{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "820px",
			"wideSize": "1440px"
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"dvh",
				"%"
			],
			"padding": true,
			"margin": true,
			"blockGap": true,
			"spacingSizes": [
				{
					"name": "XS",
					"slug": "20",
					"size": "clamp(12px, 2vw, 16px)"
				},
				{
					"name": "S",
					"slug": "30",
					"size": "clamp(16px, 2.5vw, 24px)"
				},
				{
					"name": "M",
					"slug": "40",
					"size": "clamp(24px, 3vw, 32px)"
				},
				{
					"name": "L",
					"slug": "50",
					"size": "clamp(32px, 4vw, 48px)"
				},
				{
					"name": "XL",
					"slug": "60",
					"size": "clamp(48px, 6vw, 72px)"
				},
				{
					"name": "2XL",
					"slug": "70",
					"size": "clamp(72px, 8vw, 112px)"
				},
				{
					"name": "3XL",
					"slug": "80",
					"size": "clamp(96px, 10vw, 140px)"
				}
			]
		},
		"color": {
			"background": true,
			"custom": false,
			"customDuotone": false,
			"customGradient": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"text": true,
			"link": true,
			"palette": [
				{
					"name": "Lima (VAXX)",
					"slug": "lima",
					"color": "#C8FF00"
				},
				{
					"name": "Preto (VAXX)",
					"slug": "preto",
					"color": "#0A0A0A"
				},
				{
					"name": "Carvão (VAXX)",
					"slug": "carvao",
					"color": "#111111"
				},
				{
					"name": "Cinza (VAXX)",
					"slug": "cinza",
					"color": "#888888"
				},
				{
					"name": "Branco",
					"slug": "branco",
					"color": "#FFFFFF"
				},
				{
					"name": "Branco 78%",
					"slug": "branco-78",
					"color": "rgba(255,255,255,0.78)"
				},
				{
					"name": "Branco 60%",
					"slug": "branco-60",
					"color": "rgba(255,255,255,0.60)"
				},
				{
					"name": "Branco 40%",
					"slug": "branco-40",
					"color": "rgba(255,255,255,0.40)"
				},
				{
					"name": "Verde status",
					"slug": "verde",
					"color": "#00FF41"
				},
				{
					"name": "Vermelho erro",
					"slug": "vermelho",
					"color": "#FF5555"
				}
			]
		},
		"typography": {
			"customFontSize": false,
			"dropCap": false,
			"fluid": true,
			"letterSpacing": true,
			"lineHeight": true,
			"textTransform": true,
			"fontFamilies": [
				{
					"name": "Barlow Condensed",
					"slug": "display",
					"fontFamily": "'Barlow Condensed', system-ui, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Barlow Condensed",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/barlow-cond-400.woff2"
							]
						},
						{
							"fontFamily": "Barlow Condensed",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/barlow-cond-700.woff2"
							]
						},
						{
							"fontFamily": "Barlow Condensed",
							"fontWeight": "800",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/barlow-cond-800.woff2"
							]
						},
						{
							"fontFamily": "Barlow Condensed",
							"fontWeight": "900",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/barlow-cond-900.woff2"
							]
						}
					]
				},
				{
					"name": "Barlow",
					"slug": "body",
					"fontFamily": "'Barlow', system-ui, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Barlow",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/barlow-400.woff2"
							]
						},
						{
							"fontFamily": "Barlow",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/barlow-500.woff2"
							]
						},
						{
							"fontFamily": "Barlow",
							"fontWeight": "600",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/barlow-600.woff2"
							]
						},
						{
							"fontFamily": "Barlow",
							"fontWeight": "700",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/barlow-700.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"name": "Eyebrow",
					"slug": "eyebrow",
					"size": "11px",
					"fluid": {
						"min": "10px",
						"max": "13px"
					}
				},
				{
					"name": "Pequeno",
					"slug": "small",
					"size": "12px",
					"fluid": {
						"min": "11px",
						"max": "13px"
					}
				},
				{
					"name": "Body",
					"slug": "body",
					"size": "15px",
					"fluid": {
						"min": "14px",
						"max": "17px"
					}
				},
				{
					"name": "Grande",
					"slug": "large",
					"size": "18px",
					"fluid": {
						"min": "16px",
						"max": "20px"
					}
				},
				{
					"name": "Título",
					"slug": "title",
					"size": "32px",
					"fluid": {
						"min": "24px",
						"max": "44px"
					}
				},
				{
					"name": "Hero",
					"slug": "hero",
					"size": "56px",
					"fluid": {
						"min": "40px",
						"max": "72px"
					}
				},
				{
					"name": "Mega",
					"slug": "mega",
					"size": "88px",
					"fluid": {
						"min": "56px",
						"max": "120px"
					}
				}
			]
		},
		"custom": {
			"container": {
				"maxWidth": "1440px",
				"paddingMobile": "20px",
				"paddingTablet": "32px",
				"paddingDesktop": "48px",
				"paddingXl": "72px"
			},
			"header": {
				"heightMobile": "64px",
				"heightDesktop": "80px"
			},
			"breadcrumb": {
				"marginTop": "24px",
				"marginTopTablet": "32px",
				"marginTopDesktop": "40px"
			},
			"ease": "cubic-bezier(0.2, 0.8, 0.2, 1)"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--preto)",
			"text": "var(--wp--preset--color--branco)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--body)",
			"fontWeight": "400",
			"lineHeight": "1.55"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "var(--wp--preset--font-size--hero)",
					"fontWeight": "900",
					"letterSpacing": "-0.01em",
					"lineHeight": "1",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--branco)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "var(--wp--preset--font-size--title)",
					"fontWeight": "900",
					"letterSpacing": "-0.01em",
					"lineHeight": "1.05",
					"textTransform": "uppercase"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "20px",
					"fontWeight": "900",
					"letterSpacing": "0.02em",
					"lineHeight": "1.2",
					"textTransform": "uppercase"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--lima)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--branco)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--lima)",
					"text": "var(--wp--preset--color--preto)"
				},
				"border": {
					"radius": "999px"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontSize": "13px",
					"fontWeight": "900",
					"letterSpacing": "0.12em",
					"textTransform": "uppercase"
				},
				"spacing": {
					"padding": {
						"top": "14px",
						"right": "24px",
						"bottom": "14px",
						"left": "24px"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Cabeçalho",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Rodapé",
			"area": "footer"
		},
		{
			"name": "mini-cart",
			"title": "Mini carrinho",
			"area": "uncategorized"
		}
	],
	"customTemplates": [
		{
			"name": "page-landing",
			"title": "Landing (full-width)",
			"postTypes": [
				"page"
			]
		},
		{
			"name": "page-legal",
			"title": "Legal (com sumário)",
			"postTypes": [
				"page"
			]
		}
	]
}